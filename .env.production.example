# =============================================================================
# AlFarm Resort - Production Environment Variables Template
# Copy this file to .env on your production server
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose / PostgreSQL
# -----------------------------------------------------------------------------
# These are used by docker-compose.yml for the postgres container
POSTGRES_DB=alfarm
POSTGRES_USER=alfarm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# Database Configuration (for Next.js app)
# -----------------------------------------------------------------------------
# When using docker-compose, DB_HOST should be 'db' (the service name)
DB_HOST=db
DB_PORT=5432
DB_USER=alfarm
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=alfarm

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# CRITICAL: Generate a secure random string!
# Run: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Your production domain (with https if using SSL)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Port to expose the app (default 3000)
APP_PORT=3000

# -----------------------------------------------------------------------------
# PayMongo Payment Gateway
# -----------------------------------------------------------------------------
# Get your keys from https://dashboard.paymongo.com/developers
PAYMONGO_SECRET_KEY=sk_test_CHANGE_ME
# Webhook secret for verifying PayMongo event signatures
# Create a webhook at https://dashboard.paymongo.com/developers/webhooks
# pointing to: https://your-domain.com/api/webhooks/paymongo
PAYMONGO_WEBHOOK_SECRET=whsk_CHANGE_ME

# -----------------------------------------------------------------------------
# Cron Job Secret
# -----------------------------------------------------------------------------
# Protects the /api/cron/expire-bookings endpoint from unauthorized access.
# Generate: openssl rand -base64 32
# Your external cron service sends: Authorization: Bearer <this-value>
CRON_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET

# -----------------------------------------------------------------------------
# Email Configuration (Optional but recommended for production)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@your-domain.com
