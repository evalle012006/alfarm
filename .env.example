# =============================================================================
# AlFarm Resort - Environment Variables Template
# Copy this file to .env.local for local development
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (Local Development)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=alfarm

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a secure random string for production
# Example: openssl rand -base64 32
JWT_SECRET=your-development-jwt-secret-change-in-production

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Email Configuration (Optional)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@alfarm.com

# -----------------------------------------------------------------------------
# PayMongo Payment Configuration
# Get keys from https://dashboard.paymongo.com/developers
# -----------------------------------------------------------------------------
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_secret_key
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_public_key
PAYMONGO_WEBHOOK_SECRET=your_webhook_secret_key

# -----------------------------------------------------------------------------
# Cron Job Security
# Used to authenticate requests to /api/cron/* 
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
CRON_SECRET=your_cron_secret_token
